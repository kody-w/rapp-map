    {
      "id": "rev5-keyless-uuid4-raw-octets",
      "description": "A keyless tail uses Hb with the 16 raw UUIDv4 octets.",
      "rappid": "rappid:@example-owner/keyless:3edc8783b43579d59a123b50a00c7faf78963a415eac9f05f80ecc826fc756f7",
      "mint": {
        "method": "uuid4-octets",
        "uuid": "00112233-4455-4677-8899-aabbccddeeff",
        "uuid_octets_hex": "00112233445546778899aabbccddeeff"
      },
      "expected_verdict": "CLEAN",
      "expected_rule": "RAPP/1 rev-5 sections 5, 6.1, and 6.2"
    },
    {
      "id": "rev5-keyed-spki-der",
      "description": "A keyed tail uses Hb with one exact DER SubjectPublicKeyInfo object.",
