      "mint": {
        "method": "uuid4-octets",
        "uuid": "00112233-4455-4677-8899-aabbccddeeff",
        "uuid_octets_hex": "00112233445546778899aabbccddeeff"
      },
      "expected_verdict": "CLEAN",
      "expected_rule": "RAPP/1 rev-5 sections 5, 6.1, and 6.2"
    },
    {
      "id": "rev5-keyed-spki-der",
      "description": "A keyed tail uses Hb with the raw DER SubjectPublicKeyInfo bytes.",
      "rappid": "rappid:@example-owner/keyed:ba71c721cbd5605b7e155f20d25efb77fecf935449bfc5bf7849da6d577773c4",
      "mint": {
        "method": "spki-der",
        "spki_der_b64": "MCowBQYDK2VwAyEA11qYAYKxCrfVS/7TyWQHOg7hcvPapiMlrwIaaPcHURo="
      },
      "expected_verdict": "CLEAN",
      "expected_rule": "RAPP/1 rev-5 sections 5, 6.1, and 6.2"
    },
    {
      "id": "rev5-forbid-untagged-spki-sha256",
      "description": "The pre-domain-separation SHA-256 of SPKI bytes is not a rev-5 mint.",
